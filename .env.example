BOT_TOKEN=123456:your-telegram-bot-token
WEBAPP_URL=https://your-public-domain.example
PORT=8080
DEV_MODE=false

# Локальный порт (только 127.0.0.1), на который системный nginx проксирует
# HTTPS для домена мини-аппа. На сервере с несколькими проектами у каждого
# должен быть свой свободный порт — проверить перед деплоем: ss -ltn | grep 8010
HTTP_PORT=8010

POSTGRES_USER=nosmoke
POSTGRES_PASSWORD=nosmoke
POSTGRES_DB=nosmoke
